<ul class="space-y-3">
	<% if (friends.length <=0) { %>
		<li class="text-gray-400 list-none text-center text-sm sm:text-base">No friends yet.</li>
	<% } else { %>
		<% friends.forEach(element => { %>
			<li class="list-none rounded-md border border-gray-500 hover:bg-gray-600 transition">
				<a href=<%= `/search/user/${element.profile.username}` %> class="flex items-center justify-between gap-3 p-2 sm:p-3">
					<div class="flex items-center gap-3 min-w-0">
						<img src="<%= `/account/avatar/${element.profile.username}` || '/images/default-avatar.png' %>" alt="Friend Avatar"
							class="w-9 h-9 sm:w-10 sm:h-10 shrink-0 rounded-full border-2 border-blue-400 bg-gray-700">
						<span class="text-base sm:text-lg truncate"><%= element.profile.username %></span>
					</div>
					<% if (element.status === "FRIENDS" && element.profile.online) { %>
						<span class="bg-blue-600 px-2.5 py-1 rounded-full font-semibold text-xs sm:text-sm shrink-0">Online</span>
					<% } else if (element.status === "FRIENDS" && !element.profile.online) { %>
						<span class="bg-black px-2.5 py-1 rounded-full font-semibold text-xs sm:text-sm shrink-0">Offline</span>
					<% } else { %>
						<span class="bg-indigo-600 px-2.5 py-1 rounded-full font-semibold text-xs sm:text-sm shrink-0">Pending</span>
					<% }%>
				</a>
			</li>
		<% }); %>
	<% } %>
</ul>
<!-- We need to check that the user can accept a friend request, rigth now it read's as pending in both
 pages -->