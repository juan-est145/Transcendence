<% var errors = typeof errors !== 'undefined' ? errors : null; %>
<% if (errors && errors.length) {  %>
<div class="bg-red-100 border border-red-400 text-red-700 px-3 sm:px-4 py-2.5 sm:py-3 rounded absolute left-1/2 transform -translate-x-1/2 top-2 w-[calc(100%-2rem)] sm:w-auto sm:min-w-[24rem] max-w-2xl mb-4 animate-fade-out z-20"
	role="alert">
	<strong class="font-bold text-sm sm:text-base">Error:</strong>
	<ul class="mt-2 list-disc list-inside text-sm sm:text-base break-words">
		<% errors.forEach((element) => { %>
			<li class="break-words"> <%= element %> </li>
		<% }); %>
	</ul>
</div>
<% } %>